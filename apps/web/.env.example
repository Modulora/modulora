# Neon PostgreSQL (development project: steep-resonance-36850182)
# Pooled connection for the application:
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Direct connection for migrations only:
DATABASE_URL_DIRECT=postgresql://user:password@host/db?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173

# GitHub OAuth (primary sign-in). Create an OAuth App:
#   https://github.com/settings/developers
# Callback URL (dev):  http://localhost:5173/api/auth/callback/github
# Callback URL (prod): https://modulora.dev/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Resend (waitlist welcome email; optional)
RESEND_API_KEY=re_your_key
# Verified-domain sender; onboarding@resend.dev only delivers to the account owner
RESEND_FROM=Modulora <hello@example.dev>

# Discord webhook for component reports (optional)
REPORT_WEBHOOK_URL=https://discord.com/api/webhooks/...

REVIEW_WEBHOOK_URL=
# Self-hosted Sandpack bundler origin (build-time, not a secret).
# dev: http://localhost:4587 (local build) · prod: https://sandpack.modulora.dev
VITE_SANDPACK_BUNDLER_URL=

# X (Twitter) OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Stripe (payments / Connect). Test keys for dev.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Direct component/collection checkout through Modulora. Keep false for alpha.
# External creator purchase links and profit-share payouts remain available.
VITE_DIRECT_MARKETPLACE_ENABLED=false

# Require verified DNS ownership for external component/collection links.
# Keep false during alpha; unverified destinations are disclosed publicly.
VITE_EXTERNAL_DOMAIN_VERIFICATION_REQUIRED=false

# Alpha access bootstrap: comma-separated operator emails. When set, these
# accounts and users with accepted, non-revoked alpha invitations resolve
# sessions; everyone else is treated as signed out.
# ALPHA_ALLOWLIST=owner@example.com

# Platform owner(s): comma-separated USER IDS gating /admin (profit-share
# distribution runs). User ids, not emails — emails are registerable /
# case-collidable assertions; ids are immutable and assigned by our DB.
# Curators do NOT get access. Unset = the admin surface doesn't exist.
# OWNER_USER_IDS=<user id from the user table>

# Modulora Plus monthly price in cents (default 800 = $8/mo).
# PLUS_PRICE_CENTS=800

# Transactional email sender (submission/review/purchase/plus emails).
# The waitlist keeps RESEND_FROM; both need a Resend-verified domain.
# RESEND_TRANSACTIONAL_FROM=Modulora <noreply@mail.modulora.dev>
# Resend template alias for transactional sends (default transactional-generic).
# RESEND_TRANSACTIONAL_TEMPLATE=transactional-generic

# Domain Connect URL signing — RSA private key (PEM, \n-escaped); public key published at _dck1.<domain> TXT
DOMAIN_CONNECT_SIGNING_KEY=""
DISCORD_FEEDBACK_WEBHOOK=""

# Homepage: waitlist (default) or platform (post-launch marketing)
LANDING_MODE=waitlist
