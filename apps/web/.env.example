# Neon PostgreSQL (development project: steep-resonance-36850182)
# Pooled connection for the application:
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Direct connection for migrations only:
DATABASE_URL_DIRECT=postgresql://user:password@host/db?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173

# GitHub OAuth (primary sign-in). Create an OAuth App:
#   https://github.com/settings/developers
# Callback URL (dev):  http://localhost:5173/api/auth/callback/github
# Callback URL (prod): https://modulora.dev/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Resend (waitlist welcome email; optional)
RESEND_API_KEY=re_your_key
# Verified-domain sender; onboarding@resend.dev only delivers to the account owner
RESEND_FROM=Modulora <hello@example.dev>

# Discord webhook for component reports (optional)
REPORT_WEBHOOK_URL=https://discord.com/api/webhooks/...

REVIEW_WEBHOOK_URL=
VITE_SANDPACK_BUNDLER_URL=
