# Client (VITE_*) values baked into PRODUCTION builds. Committed on purpose:
# these are public, non-secret build-time constants. `vite build` loads this
# file over .env, so deploys from any machine never embed dev values.
VITE_SANDPACK_BUNDLER_URL=https://sandpack.modulora.dev
VITE_DIRECT_MARKETPLACE_ENABLED=false
VITE_EXTERNAL_DOMAIN_VERIFICATION_REQUIRED=false
